# Required environment variables — copy this to .env.local and fill in your values
EXPO_PUBLIC_API_URL=
EXPO_PUBLIC_MAPBOX_ACCESS_TOKEN=

# Optional local convenience for native build environments.
# In EAS, set this as a secret env var instead of committing it.
RNMAPBOX_MAPS_DOWNLOAD_TOKEN=

# Legacy/fallback key used by some Android build setups.
MAPBOX_DOWNLOADS_TOKEN=
